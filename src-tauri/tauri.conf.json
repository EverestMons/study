{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Study",
  "version": "0.2.16",
  "identifier": "com.everestmons.study",
  "build": {
    "beforeDevCommand": "npx vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npx vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Study",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src ipc: http://ipc.localhost https://api.anthropic.com https://tessdata.projectnaptha.com https://cdn.jsdelivr.net; img-src 'self' data: blob: asset: https://asset.localhost; worker-src 'self' blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5Rjk1QjEwMkZENEE5QzAKUldUQXFkUXZFRnY1aVZIdExpM1c3NjF2U3Rkazkzekg1TnluNmk4dytCV2NFaWdwMTNiSXV4R08K",
      "endpoints": [
        "https://github.com/EverestMons/study/releases/latest/download/latest.json"
      ]
    }
  }
}
