{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Study",
  "version": "0.1.0",
  "identifier": "com.study.app",
  "build": {
    "beforeDevCommand": "npx vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npx vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Study",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src https://api.anthropic.com https://tessdata.projectnaptha.com https://cdn.jsdelivr.net; img-src 'self' data: blob:; worker-src 'self' blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
